<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Control Academico MVC</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="border-bottom bg-white">
        <nav class="navbar navbar-expand-sm navbar-light container">
            <a class="navbar-brand fw-semibold" asp-controller="Estudiante" asp-action="Listar">Control Academico</a>
            <div class="navbar-nav">
                <a class="nav-link" asp-controller="Estudiante" asp-action="Listar">Estudiantes</a>
            </div>
        </nav>
    </header>

    <main class="container py-4">
        @RenderBody()
    </main>

    <footer class="border-top text-muted py-3">
        <div class="container small">IPC2 - Actividad 17 de Junio</div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
